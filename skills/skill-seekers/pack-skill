#!/usr/bin/env bash
set -euo pipefail

# ============================================================
# pack-skill - 一键打包各种来源为 OpenCode Skill
# 支持: github / docs / pdf / codebase / text / file / unified
# ============================================================

PROXY_DEFAULT="http://127.0.0.1:7897"
SKILLS_DIR="$HOME/.config/opencode/skills"
WORK_DIR="$SKILLS_DIR/skill-seekers/_work"

# 颜色
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

info()  { echo -e "${BLUE}[pack-skill]${NC} $*"; }
ok()    { echo -e "${GREEN}[pack-skill]${NC} ✅ $*"; }
warn()  { echo -e "${YELLOW}[pack-skill]${NC} ⚠️  $*"; }
err()   { echo -e "${RED}[pack-skill]${NC} ❌ $*" >&2; exit 1; }

usage() {
  cat << 'USAGE'
用法:
  pack-skill github  <owner/repo>     [--name NAME]
  pack-skill docs    <url>            [--name NAME] [--max-pages N]
  pack-skill pdf     <文件路径>        [--name NAME]
  pack-skill codebase <目录>          [--name NAME] [--depth surface|deep|full]
  pack-skill text    "一段文字"        --name NAME
  pack-skill file    <文件路径>        [--name NAME]
  pack-skill unified <config.json>    [--name NAME]

选项:
  --name NAME       指定 skill 名称（不指定则自动生成）
  --no-enhance      跳过 AI 增强步骤
  --max-pages N     docs 模式：最大抓取页数
  --depth LEVEL     codebase 模式：分析深度 (surface/deep/full)
  --help            显示帮助

示例:
  pack-skill github microsoft/TypeScript --name typescript
  pack-skill docs https://react.dev --name react --max-pages 200
  pack-skill pdf ~/Downloads/manual.pdf --name manual
  pack-skill codebase ./my-project --name my-project
  pack-skill text "这是一段学习资料..." --name my-notes
  pack-skill file ~/notes.md --name notes

代理设置:
  默认使用 http://127.0.0.1:7897
  可通过 HTTP_PROXY/HTTPS_PROXY 环境变量覆盖
USAGE
}

# 清理名称（文件系统友好）
sanitize_name() {
  echo "$1" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9._-]+/-/g; s/^-+//; s/-+$//'
}

# 从 URL 自动生成名称
name_from_url() {
  local url="$1"
  local host=$(echo "$url" | sed -E 's#^https?://([^/]+).*#\1#')
  local path=$(echo "$url" | sed -E 's#^https?://[^/]+/?##')
  local last=$(echo "$path" | awk -F/ '{print $1}')
  [[ -n "$last" ]] || last="docs"
  sanitize_name "${host}-${last}"
}

# 确保有 SKILL.md 入口
ensure_skill_md() {
  local dir="$1"
  local name="$2"
  [[ -f "$dir/SKILL.md" ]] && return 0
  
  cat > "$dir/SKILL.md" << EOM
# $name

## 目的
使用本目录中的资料回答问题，并给出可执行的步骤。

## 使用方式
- 先概览本 skill 的主要内容
- 回答时优先引用本目录的资料
- 给出可复制粘贴的命令或步骤

## 内容
查看本目录下的文件获取详细信息。
EOM
}

# 同步到目标目录
sync_to_dest() {
  local src="$1"
  local dest="$2"
  local name="$3"
  
  [[ -d "$src" ]] || err "源目录不存在: $src"
  
  mkdir -p "$dest"
  
  if command -v rsync &>/dev/null; then
    rsync -a --delete "$src/" "$dest/"
  else
    rm -rf "$dest"/*
    cp -R "$src/." "$dest/"
  fi
  
  ensure_skill_md "$dest" "$name"
}

# ============================================================
# 主逻辑
# ============================================================

[[ $# -lt 1 ]] && { usage; exit 1; }
[[ "$1" == "-h" || "$1" == "--help" ]] && { usage; exit 0; }

MODE="$1"; shift
INPUT="${1:-}"; [[ -n "$INPUT" && "$INPUT" != --* ]] && shift || INPUT=""

# 解析参数
NAME=""
NO_ENHANCE=0
MAX_PAGES=""
DEPTH="deep"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --name) NAME="$2"; shift 2 ;;
    --no-enhance) NO_ENHANCE=1; shift ;;
    --max-pages) MAX_PAGES="$2"; shift 2 ;;
    --depth) DEPTH="$2"; shift 2 ;;
    --help) usage; exit 0 ;;
    *) err "未知参数: $1" ;;
  esac
done

# 设置代理
export HTTP_PROXY="${HTTP_PROXY:-$PROXY_DEFAULT}"
export HTTPS_PROXY="${HTTPS_PROXY:-$PROXY_DEFAULT}"

# 创建工作目录
mkdir -p "$WORK_DIR"
cd "$WORK_DIR"

# 自动生成名称
if [[ -z "$NAME" ]]; then
  case "$MODE" in
    github)
      [[ -n "$INPUT" ]] || err "github 需要 <owner/repo>"
      NAME="${INPUT//\//-}" ;;
    docs)
      [[ -n "$INPUT" ]] || err "docs 需要 <url>"
      NAME="$(name_from_url "$INPUT")" ;;
    pdf|file)
      [[ -n "$INPUT" ]] || err "$MODE 需要 <文件路径>"
      NAME="$(basename "$INPUT")"
      NAME="${NAME%.*}"
      NAME="$(sanitize_name "$NAME")" ;;
    codebase)
      [[ -n "$INPUT" ]] || err "codebase 需要 <目录>"
      NAME="$(basename "$(cd "$INPUT" && pwd)")"
      NAME="$(sanitize_name "$NAME")" ;;
    unified)
      NAME="unified-$(date +%Y%m%d%H%M%S)" ;;
    text)
      NAME="text-$(date +%Y%m%d%H%M%S)" ;;
    *) err "未知模式: $MODE" ;;
  esac
fi

NAME="$(sanitize_name "$NAME")"
[[ -n "$NAME" ]] || err "无法生成名称，请用 --name 指定"

DEST="$SKILLS_DIR/$NAME"
OUTDIR=""

info "模式: $MODE"
info "名称: $NAME"
info "目标: $DEST"
echo ""

# ============================================================
# 执行各模式
# ============================================================

case "$MODE" in
  github)
    [[ -n "$INPUT" ]] || err "需要 <owner/repo>"
    info "抓取 GitHub 仓库: $INPUT"
    skill-seekers github --repo "$INPUT" --name "$NAME"
    OUTDIR="output/$NAME"
    ;;
    
  docs)
    [[ -n "$INPUT" ]] || err "需要 <url>"
    info "抓取文档网站: $INPUT"
    args=("$INPUT" --name "$NAME")
    [[ -n "$MAX_PAGES" ]] && args+=(--max-pages "$MAX_PAGES")
    skill-seekers scrape "${args[@]}"
    OUTDIR="output/$NAME"
    ;;
    
  pdf)
    [[ -n "$INPUT" ]] || err "需要 <pdf文件路径>"
    [[ -f "$INPUT" ]] || err "文件不存在: $INPUT"
    INPUT="$(cd "$(dirname "$INPUT")" && pwd)/$(basename "$INPUT")"
    info "提取 PDF: $INPUT"
    skill-seekers pdf --pdf "$INPUT" --name "$NAME"
    OUTDIR="output/$NAME"
    ;;
    
  codebase)
    [[ -n "$INPUT" ]] || err "需要 <目录>"
    [[ -d "$INPUT" ]] || err "目录不存在: $INPUT"
    INPUT="$(cd "$INPUT" && pwd)"
    info "分析代码库: $INPUT (深度: $DEPTH)"
    OUTDIR="output/${NAME}-codebase"
    skill-seekers-codebase --directory "$INPUT" --output "$OUTDIR" --depth "$DEPTH" --ai-mode none
    ;;
    
  unified)
    [[ -n "$INPUT" ]] || err "需要 <config.json>"
    [[ -f "$INPUT" ]] || err "配置文件不存在: $INPUT"
    INPUT="$(cd "$(dirname "$INPUT")" && pwd)/$(basename "$INPUT")"
    info "多源统一抓取: $INPUT"
    skill-seekers unified --config "$INPUT"
    # unified 输出目录可能在 config 里定义
    if [[ -d "output/$NAME" ]]; then
      OUTDIR="output/$NAME"
    else
      # 找最新的输出目录
      OUTDIR=$(ls -td output/*/ 2>/dev/null | head -1)
      OUTDIR="${OUTDIR%/}"
    fi
    ;;
    
  text)
    [[ -n "$INPUT" ]] || err "需要一段文字（用引号包裹）"
    info "创建文本 skill: $NAME"
    OUTDIR="output/$NAME"
    mkdir -p "$OUTDIR"
    echo "$INPUT" > "$OUTDIR/SOURCE.txt"
    cat > "$OUTDIR/SKILL.md" << EOM
# $NAME

## 目的
使用 SOURCE.txt 中的内容作为权威资料，帮助回答问题、总结要点。

## 使用方式
- 先用几句话总结 SOURCE.txt 的核心内容
- 回答时优先引用 SOURCE.txt 的事实
- 如适用，给出清晰的操作步骤或学习建议

## 资料
- SOURCE.txt
EOM
    ;;
    
  file)
    [[ -n "$INPUT" ]] || err "需要 <文件路径>"
    [[ -f "$INPUT" ]] || err "文件不存在: $INPUT"
    INPUT="$(cd "$(dirname "$INPUT")" && pwd)/$(basename "$INPUT")"
    info "创建文件 skill: $NAME"
    OUTDIR="output/$NAME"
    mkdir -p "$OUTDIR"
    ext="${INPUT##*.}"
    cp "$INPUT" "$OUTDIR/SOURCE.$ext"
    cat > "$OUTDIR/SKILL.md" << EOM
# $NAME

## 目的
使用 SOURCE.$ext 的内容回答问题、总结要点。

## 使用方式
- 先概览 SOURCE.$ext 的结构与主题
- 回答时优先引用该文件内容
- 如适用，给出可执行的步骤

## 资料
- SOURCE.$ext
EOM
    ;;
    
  *)
    err "未知模式: $MODE (可用: github/docs/pdf/codebase/text/file/unified)"
    ;;
esac

# ============================================================
# 增强（可选）
# ============================================================

if [[ "$NO_ENHANCE" != "1" && -d "$OUTDIR" ]]; then
  case "$MODE" in
    github|docs|pdf|unified)
      info "执行 AI 增强..."
      if skill-seekers enhance "$OUTDIR" 2>/dev/null; then
        ok "增强完成"
      else
        warn "增强失败（已跳过，产物仍可用）"
      fi
      ;;
  esac
fi

# ============================================================
# 同步到目标目录
# ============================================================

[[ -d "$OUTDIR" ]] || err "输出目录不存在: $OUTDIR"

info "同步到 $DEST ..."
sync_to_dest "$OUTDIR" "$DEST" "$NAME"

echo ""
ok "完成！Skill 已安装到: $DEST"
echo ""
info "目录内容:"
ls -la "$DEST" | head -15
echo ""
info "在 OpenCode 中使用:"
echo "  \"使用 skill $NAME：先总结它的内容，然后回答我的问题\""
