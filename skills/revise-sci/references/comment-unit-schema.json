{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Revise SCI Comment Unit",
  "type": "object",
  "required": [
    "comment_id",
    "reviewer",
    "severity",
    "reviewer_comment_en",
    "reviewer_comment_zh_literal",
    "intent_zh",
    "response_zh",
    "response_en",
    "atomic_location",
    "original_excerpt_en",
    "revised_excerpt_en",
    "revised_excerpt_zh",
    "modification_actions",
    "notes_core_zh",
    "notes_support_zh",
    "evidence_sources",
    "target_document",
    "status",
    "author_confirmation_reason"
  ],
  "properties": {
    "comment_id": { "type": "string" },
    "reviewer": { "type": "string" },
    "severity": { "type": "string", "enum": ["major", "minor"] },
    "reviewer_comment_en": { "type": "string" },
    "reviewer_comment_zh_literal": { "type": "string" },
    "intent_zh": { "type": "string" },
    "response_zh": { "type": "string" },
    "response_en": { "type": "string" },
    "atomic_location": { "type": "object" },
    "original_excerpt_en": { "type": "string" },
    "revised_excerpt_en": { "type": "string" },
    "revised_excerpt_zh": { "type": "string" },
    "modification_actions": { "type": "array" },
    "notes_core_zh": { "type": "array" },
    "notes_support_zh": { "type": "array" },
    "evidence_sources": { "type": "array" },
    "target_document": { "type": "string" },
    "status": { "type": "string" },
    "author_confirmation_reason": { "type": "string" }
  }
}
