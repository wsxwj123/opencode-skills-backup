{
  "$schema": "https://opencode.ai/config.json",
  "model": "deepseek/deepseek-chat",
  "plugin": [
    "oh-my-opencode-slim"
  ],
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "C:\\Users\\username", "C:\\Users\\username\\Desktop"],
      "enabled": true
    },
    "memory": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"],
      "enabled": true
    },
    "tavily": {
      "type": "local",
      "command": ["npx", "-y", "tavily-mcp@0.1.4"],
      "environment": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      },
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx.cmd", "-y", "@executeautomation/playwright-mcp-server"],
      "enabled": true
    },
    "quickchart": {
      "type": "local",
      "command": ["node", "C:\\Program Files\\quickchart-mcp-server\\index.js"],
      "enabled": true
    }
  },
  "provider": {
    "openai": {
      "npm": "@ai-sdk/openai",
      "options": {
        "apiKey": "${OPENAI_API_KEY}"
      }
    },
    "anthropic": {
      "npm": "@ai-sdk/anthropic",
      "options": {
        "apiKey": "${ANTHROPIC_API_KEY}"
      }
    }
  },
  "environment": {
    "PATH": "C:\\Python39;C:\\Program Files\\nodejs;C:\\Program Files\\Git\\cmd",
    "PYTHONPATH": "C:\\Python39\\Lib\\site-packages",
    "NODE_PATH": "C:\\Program Files\\nodejs\\node_modules",
    "OPENCODE_CONFIG_DIR": "C:\\Users\\username\\.config\\opencode",
    "LOG_LEVEL": "info",
    "NODE_OPTIONS": "--max-old-space-size=4096"
  },
  "platform_specific": {
    "notes": [
      "使用反斜杠作为路径分隔符",
      "命令可能需要 .cmd 扩展名",
      "环境变量使用分号分隔",
      "可能需要管理员权限"
    ]
  }
}