{
  "_comment": "多模型提供商配置 - 通过 active_provider 一键切换",
  "active_provider": "fangzhou",

  "providers": {
    "deepseek": {
      "name": "DeepSeek",
      "type": "openai_compatible",
      "base_url": "https://api.deepseek.com/v1",
      "api_key_env": "DEEPSEEK_API_KEY",
      "model": "deepseek-chat",
      "alt_models": ["deepseek-reasoner"],
      "max_tokens": 8192,
      "temperature": 0.7
    },
    "maoshu": {
      "name": "猫鼠 API (GPT-5 系列)",
      "type": "openai_compatible",
      "base_url": "https://ai.ll9e.cn/v1",
      "api_key_env": "MAOSHU_API_KEY",
      "model": "gpt-5.2",
      "alt_models": ["gpt-5.1", "gpt-5", "gpt-5.3-codex", "gpt-5.1-codex", "gpt-5-codex"],
      "max_tokens": 8192,
      "temperature": 0.7
    },
    "fangzhou": {
      "name": "方舟 API (Claude/Gemini 全系列)",
      "type": "openai_compatible",
      "base_url": "https://www.yxaiapp.com/v1",
      "api_key_env": "FANGZHOU_API_KEY",
      "model": "claude-sonnet-4-6",
      "alt_models": [
        "claude-opus-4-6", "claude-opus-4-6-thinking",
        "claude-opus-4-5", "claude-opus-4-5-thinking",
        "claude-sonnet-4-5", "claude-sonnet-4-5-20250929",
        "claude-haiku-4-5",
        "gemini-2.5-pro", "gemini-2.5-flash",
        "gemini-3-flash", "gemini-3-pro-preview",
        "gemini-3.1-pro-preview"
      ],
      "max_tokens": 8192,
      "temperature": 0.7
    }
  },

  "claude_code_overrides": {
    "_comment": "当使用 Claude Code CLI 时的额外配置",
    "use_claude_code_cli": true,
    "cli_path": "claude",
    "dangerously_skip_permissions": true
  }
}
