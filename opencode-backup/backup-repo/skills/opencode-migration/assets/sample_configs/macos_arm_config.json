{
  "$schema": "https://opencode.ai/config.json",
  "model": "deepseek/deepseek-chat",
  "plugin": [
    "oh-my-opencode-slim"
  ],
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "/Users/username", "/Users/username/Desktop"],
      "enabled": true
    },
    "memory": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"],
      "enabled": true
    },
    "tavily": {
      "type": "local",
      "command": ["npx", "-y", "tavily-mcp@0.1.4"],
      "environment": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      },
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@executeautomation/playwright-mcp-server"],
      "enabled": true
    },
    "quickchart": {
      "type": "local",
      "command": ["node", "/opt/homebrew/bin/quickchart-mcp-server"],
      "enabled": true
    }
  },
  "provider": {
    "openai": {
      "npm": "@ai-sdk/openai",
      "options": {
        "apiKey": "${OPENAI_API_KEY}"
      }
    },
    "anthropic": {
      "npm": "@ai-sdk/anthropic",
      "options": {
        "apiKey": "${ANTHROPIC_API_KEY}"
      }
    }
  },
  "environment": {
    "PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin",
    "PYTHONPATH": "/opt/homebrew/lib/python3.11/site-packages",
    "NODE_PATH": "/opt/homebrew/lib/node_modules",
    "OPENCODE_CONFIG_DIR": "/Users/username/.config/opencode",
    "LOG_LEVEL": "info"
  }
}