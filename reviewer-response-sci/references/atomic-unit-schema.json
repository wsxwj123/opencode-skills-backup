{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Reviewer Response Atomic Unit",
  "type": "object",
  "required": [
    "unit_id",
    "order",
    "reviewer",
    "section",
    "comment_number",
    "title",
    "content",
    "status",
    "source",
    "links"
  ],
  "properties": {
    "unit_id": { "type": "string" },
    "order": { "type": "integer", "minimum": 0 },
    "reviewer": { "type": "string" },
    "section": { "type": "string", "enum": ["major", "minor", "general", "email"] },
    "comment_number": { "type": "string" },
    "title": { "type": "string" },
    "source": {
      "type": "object",
      "required": ["comments_docx", "manuscript_docx", "si_docx"],
      "properties": {
        "comments_docx": { "type": "string" },
        "manuscript_docx": { "type": "string" },
        "si_docx": { "type": "string" }
      }
    },
    "links": {
      "type": "object",
      "required": ["anchors", "manuscript_unit_ids", "si_unit_ids"],
      "properties": {
        "anchors": { "type": "array", "items": { "type": "string" } },
        "manuscript_unit_ids": { "type": "array", "items": { "type": "string" } },
        "si_unit_ids": { "type": "array", "items": { "type": "string" } }
      }
    },
    "content": {
      "type": "object",
      "required": [
        "reviewer_comment_zh",
        "reviewer_comment_en",
        "response_en",
        "revised_excerpt_en",
        "notes_core_zh",
        "notes_support_zh",
        "evidence"
      ],
      "properties": {
        "reviewer_comment_zh": { "type": "string" },
        "reviewer_comment_en": { "type": "string" },
        "response_en": { "type": "string" },
        "revised_excerpt_en": { "type": "string" },
        "notes_core_zh": { "type": "array", "items": { "type": "string" } },
        "notes_support_zh": { "type": "array", "items": { "type": "string" } },
        "evidence": {
          "type": "object",
          "required": ["text", "images", "table"],
          "properties": {
            "text": { "type": "array", "items": { "type": "string" } },
            "images": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["src", "alt", "caption"],
                "properties": {
                  "src": { "type": "string" },
                  "alt": { "type": "string" },
                  "caption": { "type": "string" }
                }
              }
            },
            "table": {
              "type": "object",
              "required": ["columns", "rows"],
              "properties": {
                "columns": { "type": "array", "items": { "type": "string" } },
                "rows": {
                  "type": "array",
                  "items": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        }
      }
    },
    "status": {
      "type": "object",
      "required": ["response_state", "excerpt_state", "notes_state"],
      "properties": {
        "response_state": { "type": "string", "enum": ["draft", "final"] },
        "excerpt_state": { "type": "string", "enum": ["draft", "final", "missing"] },
        "notes_state": { "type": "string", "enum": ["draft", "final"] }
      }
    }
  }
}
