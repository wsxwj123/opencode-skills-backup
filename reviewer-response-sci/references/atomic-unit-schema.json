{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Reviewer Response Atomic Unit",
  "type": "object",
  "required": [
    "unit_id",
    "order",
    "reviewer",
    "section",
    "comment_number",
    "title",
    "content",
    "status",
    "source",
    "links"
  ],
  "properties": {
    "unit_id": { "type": "string" },
    "order": { "type": "integer", "minimum": 0 },
    "reviewer": { "type": "string" },
    "section": { "type": "string", "enum": ["major", "minor", "general", "email"] },
    "comment_number": { "type": "string" },
    "title": { "type": "string" },
    "source": {
      "type": "object",
      "required": ["comments_docx", "manuscript_docx", "si_docx"],
      "properties": {
        "comments_docx": { "type": "string" },
        "manuscript_docx": { "type": "string" },
        "si_docx": { "type": "string" }
      }
    },
    "links": {
      "type": "object",
      "required": ["anchors", "manuscript_unit_ids", "si_unit_ids"],
      "properties": {
        "anchors": { "type": "array", "items": { "type": "string" } },
        "manuscript_unit_ids": { "type": "array", "items": { "type": "string" } },
        "si_unit_ids": { "type": "array", "items": { "type": "string" } }
      }
    },
    "content": {
      "type": "object",
      "required": [
        "reviewer_comment_zh",
        "reviewer_comment_en",
        "reviewer_intent_zh",
        "response_en",
        "response_zh",
        "original_excerpt_en",
        "revised_excerpt_en",
        "revised_excerpt_zh",
        "atomic_location",
        "modification_actions",
        "notes_core_zh",
        "notes_support_zh",
        "evidence"
      ],
      "properties": {
        "reviewer_comment_zh": { "type": "string", "description": "Chinese translation of reviewer comment (direct/literal)" },
        "reviewer_comment_en": { "type": "string", "description": "Original reviewer comment in English" },
        "reviewer_intent_zh": { "type": "string", "description": "Chinese summary of reviewer intent/understanding" },
        "response_en": { "type": "string", "description": "English response to reviewer" },
        "response_zh": { "type": "string", "description": "Chinese response to reviewer" },
        "original_excerpt_en": { "type": "string", "description": "Original manuscript paragraph excerpt for comparison" },
        "revised_excerpt_en": { "type": "string", "description": "Revised manuscript text in English" },
        "revised_excerpt_zh": { "type": "string", "description": "Chinese translation of revised manuscript text" },
        "atomic_location": {
          "type": "object",
          "description": "Location anchor linking comment to manuscript/SI units",
          "required": ["manuscript_unit_id", "manuscript_sentence_index"],
          "properties": {
            "manuscript_unit_id": { "type": "string" },
            "si_unit_id": { "type": "string", "default": "" },
            "manuscript_paragraph_index": { "type": "integer" },
            "manuscript_sentence_index": { "type": "integer" },
            "matched_sentence": { "type": "string" },
            "confidence": { "type": "string", "enum": ["high", "medium", "low"], "default": "high" }
          }
        },
        "modification_actions": {
          "type": "array",
          "description": "List of modification actions with type and reason",
          "items": {
            "type": "object",
            "required": ["action_type", "reason"],
            "properties": {
              "action_type": { "type": "string", "enum": ["添加", "删除", "修改"] },
              "target": { "type": "string", "description": "What is being modified" },
              "reason": { "type": "string", "description": "Why this modification is needed" }
            }
          }
        },
        "strategy": {
          "type": "string",
          "enum": ["Accept", "Partial", "Push back", "Acknowledge", ""],
          "default": "",
          "description": "Rebuttal strategy decided in Step 1.7 strategy table; drives tone in Step 7 response authoring"
        },
        "figure_prompt": { "type": "string", "default": "", "description": "Structured figure revision prompt; empty if no figure change needed" },
        "notes_core_zh": { "type": "array", "items": { "type": "string" }, "description": "Core modification notes (marked 🔴)" },
        "notes_support_zh": { "type": "array", "items": { "type": "string" }, "description": "Support modification notes (marked 🟡)" },
        "evidence": {
          "type": "object",
          "required": ["text", "images", "table"],
          "properties": {
            "text": { "type": "array", "items": { "type": "string" } },
            "images": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["src", "alt", "caption"],
                "properties": {
                  "src": { "type": "string" },
                  "alt": { "type": "string" },
                  "caption": { "type": "string" }
                }
              }
            },
            "table": {
              "type": "object",
              "required": ["columns", "rows"],
              "properties": {
                "columns": { "type": "array", "items": { "type": "string" } },
                "rows": {
                  "type": "array",
                  "items": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        }
      }
    },
    "status": {
      "type": "object",
      "required": ["response_state", "excerpt_state", "notes_state"],
      "properties": {
        "response_state": { "type": "string", "enum": ["draft", "final"] },
        "excerpt_state": { "type": "string", "enum": ["draft", "final", "missing", "needs_manual_revision"] },
        "notes_state": { "type": "string", "enum": ["draft", "final"] }
      }
    }
  }
}
